# Prod / Docker: same-origin API через хостовый nginx
VITE_API_BASE_URL=/api

# Dev override — локальный anomaly-api:
# VITE_API_BASE_URL=http://localhost:8000/api

# Auth guard: true (default) — require M19 session; false — bypass for e2e
VITE_MOCK_AUTH_ENABLED=true

# Fixtures без API: dev — автоматически; prod preview — явно true
VITE_USE_API_FIXTURES=true
