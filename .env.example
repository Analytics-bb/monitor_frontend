# Dev: Vite dev-server → local or staging anomaly-api
VITE_ANOMALY_API_BASE_URL=http://localhost:8000

# Mock auth (R2): false — bypass route guards for dev/e2e (default true)
VITE_MOCK_AUTH_ENABLED=true

# Fixtures без API: dev — автоматически; prod preview/Pages — явно true
VITE_USE_API_FIXTURES=true

# GitHub Pages project site only (workflow sets automatically):
VITE_BASE_PATH=/monitor_frontend/
